# Database
DATABASE_URL=postgresql+asyncpg://crmkit:crmkit@localhost:15432/crmkit
DATABASE_URL_SYNC=postgresql://crmkit:crmkit@localhost:15432/crmkit

# Redis
REDIS_URL=redis://localhost:16379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_REFRESH_TOKEN_SHORT_EXPIRE_HOURS=24

# Password
PASSWORD_MIN_LENGTH=8

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
